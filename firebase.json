{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "server/**",
      "tools/**",
      "content/**",
      "docs/**",
      "*.md"
    ],
    "rewrites": [],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|json|webmanifest)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      }
    ]
  }
}
