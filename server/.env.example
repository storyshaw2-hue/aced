# ACED server config — copy to .env and fill in. Never commit the real .env.

# Where the static app is served (used for CORS + auth redirect + Stripe return URLs).
APP_URL=http://localhost:5500
# Public URL of THIS API (used to build the magic link).
API_URL=http://localhost:8787
PORT=8787

# Session signing. Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me

# SQLite file (swap for a Postgres DSN + driver in production).
DB_PATH=aced.db

# Stripe — leave blank to run with billing disabled (sync + accounts still work).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time per-section unlock Price IDs (create products/prices in the Stripe dashboard).
PRICE_CPA_FAR=
PRICE_CPA_AUD=

# Set to "production" to stop returning the magic link in the API response.
NODE_ENV=development
